# Copy this to .env.local for local development

REACT_APP_DJANGO_API_URL=http://localhost:8000/api
REACT_APP_FASTAPI_URL=http://localhost:8001

# Google Apps Script — Contact Form
REACT_APP_GAS_CONTACT_URL=

# EmailJS — Auth emails (verification, password reset)
# Dashboard: https://dashboard.emailjs.com/
# 1. Create an Email Service (Gmail, Outlook, etc.) → copy Service ID
# 2. Create two templates (verification + password reset) → copy Template IDs
# 3. Account > API Keys → copy Public Key
REACT_APP_EMAILJS_PUBLIC_KEY=
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_VERIFY=
REACT_APP_EMAILJS_TEMPLATE_RESET=
REACT_APP_EMAILJS_TEMPLATE_WELCOME=
